    "@sentry/nextjs": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "@tailwindcss/typography": "^0.5.20",
    "@tanstack/react-query": "catalog:",
    "@types/turndown": "^5.0.6",
    "@vercel/analytics": "catalog:",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dompurify": "^3.4.9",
    "graphql": "^16.12.0",
    "lucide-react": "catalog:",
    "next": "catalog:",
