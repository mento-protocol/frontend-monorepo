{
  "name": "governance.mento.org",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build --turbopack",
    "postbuild": "node ../../scripts/assert-next-sharp-trace.mjs .next",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .next && rm -rf .turbo",
    "codegen": "graphql-codegen",
    "dev": "next dev --turbopack --port 3002",
    "lint": "npx @trunkio/launcher check",
    "start": "next start",
    "test": "vitest run",
    "test:connected": "playwright test --project=connected",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
