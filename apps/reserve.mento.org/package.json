{
  "name": "reserve.mento.org",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build --turbopack",
    "postbuild": "node ../../scripts/assert-next-sharp-trace.mjs .next",
    "check-types": "NEXT_PUBLIC_STORAGE_URL=https://example.com NEXT_PUBLIC_SENTRY_DSN_RESERVE= SENTRY_AUTH_TOKEN= next typegen && tsc --noEmit",
    "clean": "rm -rf .next && rm -rf .turbo",
    "dev": "next dev --turbopack --port 3001",
    "lint": "npx @trunkio/launcher check",
    "start": "next start"
  },
  "dependencies": {
    "@mento-protocol/ui": "workspace:*",
    "@repo/web3": "workspace:*",
    "@sentry/nextjs": "catalog:",
    "@t3-oss/env-nextjs": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@vercel/analytics": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "postcss": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:"
  }
}
