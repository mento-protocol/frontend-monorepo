{
  "name": "ui.mento.org",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build --turbopack",
    "postbuild": "node ../../scripts/assert-next-sharp-trace.mjs .next",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf .next && rm -rf .turbo",
    "dev": "next dev --turbopack --port 3003",
    "lint": "npx @trunkio/launcher check .",
    "start": "next start",
    "test:visual": "playwright test"
  },
  "dependencies": {
    "@mento-protocol/ui": "workspace:*",
    "@t3-oss/env-nextjs": "catalog:",
    "lucide-react": "catalog:",
    "next": "catalog:",
    "next-themes": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@argos-ci/playwright": "7.1.2",
    "@playwright/test": "1.61.1",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@tailwindcss/postcss": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "eslint": "catalog:",
    "postcss": "catalog:",
    "typescript": "catalog:"
  }
}
