{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "ignoreBinaries": ["anvil"],
  "ignoreWorkspaces": ["packages/typescript-config"],
  "ignore": [
    ".trunk/**",
    "commitlint.config.mjs",
    "scripts/security-headers.d.mts"
  ],
  "workspaces": {
    ".": {
      "ignoreDependencies": ["zod"]
    },
    "apps/*": {
      "project": "app/**/*.{mjs,tsx,ts}"
    },
    "apps/app.mento.org": {
      "entry": ["e2e/**/*.spec.ts"],
      "project": "{app,e2e}/**/*.{mjs,tsx,ts}",
      "ignoreDependencies": ["pino-pretty", "tailwindcss"]
    },
    "apps/governance.mento.org": {
      "ignoreDependencies": ["pino-pretty"]
    },
    "apps/reserve.mento.org": {},
    "apps/ui.mento.org": {
      "entry": ["e2e/**/*.spec.ts"],
      "project": "{app,e2e}/**/*.{mjs,tsx,ts}"
    },
    "packages/*": {
      "project": "**/*.{ts,tsx}"
    },
    "packages/ui": {
      "entry": ["turbo/generators/config.ts"],
      "project": "**/*.{ts,tsx}",
      "ignoreDependencies": ["tailwindcss", "tw-animate-css"]
    },
    "packages/eslint-config": {
      "entry": "*.js",
      "project": "**/*.js"
    },
    "packages/vitest-config": {
      "entry": "*.js",
      "project": "**/*.js"
    }
  }
}
