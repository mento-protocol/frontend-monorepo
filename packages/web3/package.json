{
  "name": "@repo/web3",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./wagmi": {
      "types": "./dist/wagmi.d.ts",
      "import": "./dist/wagmi.js",
      "require": "./dist/wagmi.cjs"
    },
    "./wagmi-ssr": {
      "types": "./dist/wagmi-ssr.d.ts",
      "import": "./dist/wagmi-ssr.js",
      "require": "./dist/wagmi-ssr.cjs"
    },
    "./sentry-filter": {
      "types": "./dist/sentry-filter.d.ts",
      "import": "./dist/sentry-filter.js",
      "require": "./dist/sentry-filter.cjs"
    },
    "./borrow-server": {
      "types": "./dist/borrow-server.d.ts",
      "import": "./dist/borrow-server.js",
      "require": "./dist/borrow-server.cjs"
    },
    "./is-user-rejection": {
      "types": "./dist/is-user-rejection.d.ts",
      "import": "./dist/is-user-rejection.js",
      "require": "./dist/is-user-rejection.cjs"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "analyze": "node scripts/analyze-build.js",
    "build": "pnpm clean && pnpm build:js",
    "build:analyze": "pnpm run build && pnpm run analyze",
    "build:js": "tsup",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist && rm -rf .turbo",
    "dev": "pnpm dev:js",
    "dev:js": "tsup --watch",
    "generate:component": "turbo gen react-component",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "watch": "pnpm dev:js"
  },
  "dependencies": {
    "@mento-protocol/mento-sdk": "catalog:",
    "@mento-protocol/ui": "workspace:*",
    "@metamask/jazzicon": "catalog:",
    "@rainbow-me/rainbowkit": "catalog:",
    "@tanstack/react-query": "catalog:",
    "bignumber.js": "^9.3.1",
    "jotai": "catalog:",
    "lucide-react": "catalog:",
    "react": "catalog:",
    "react-hook-form": "catalog:",
    "viem": "catalog:",
    "wagmi": "catalog:"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@repo/vitest-config": "workspace:*",
    "@sentry/nextjs": "catalog:",
    "@testing-library/react": "^16.3.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "esbuild-plugin-preserve-directives": "catalog:",
    "eslint": "catalog:",
    "jsdom": "^29.1.1",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
